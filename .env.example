# === Variables de entorno ===
# Copia este archivo a .env y completa los valores.

# --- Base de datos Oracle (Semana 1) ---
spring.datasource.url=jdbc:oracle:thin:@<db_alias>?TNS_ADMIN=/app/wallet
spring.datasource.username=<db_user>
spring.datasource.password=<db_password>

# --- AWS S3 (Semana 2) ---
# Credenciales del AWS Academy Learner Lab: son TEMPORALES y caducan; requieren session token.
# Toma los valores desde "AWS Details" -> "AWS CLI" en el Learner Lab.
AWS_REGION=us-east-1
AWS_S3_BUCKET=<nombre-de-tu-bucket>
AWS_ACCESS_KEY_ID=<access-key-temporal>
AWS_SECRET_ACCESS_KEY=<secret-key-temporal>
AWS_SESSION_TOKEN=<session-token-temporal>
