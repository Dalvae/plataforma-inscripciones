# === Variables de entorno ===
# Local: copia a .env y completa. En el EC2 las inyecta el pipeline de GitHub Actions.

# --- Base de datos Oracle (contenedor docker-compose) ---
# Para correr local con el compose no necesitas tocar nada (usa los defaults).
ORACLE_PASSWORD=OraclePlat2026
APP_USER=plataforma
APP_USER_PASSWORD=PlataPass2026
# La app arma la URL: jdbc:oracle:thin:@//oracle:1521/FREEPDB1 (servicio 'oracle' del compose)

# --- Imagen de la app ---
APP_IMAGE=dalvaes/plataforma-inscripciones:latest

# --- AWS S3 (Semana 2) ---
# En EC2: NO se setean credenciales; la app usa el rol de instancia (LabInstanceProfile).
# Solo local: si quieres probar S3 desde tu maquina, exporta las 3 creds temporales del Learner Lab.
AWS_REGION=us-east-1
AWS_S3_BUCKET=<nombre-de-tu-bucket>
# AWS_ACCESS_KEY_ID=<access-key-temporal>
# AWS_SECRET_ACCESS_KEY=<secret-key-temporal>
# AWS_SESSION_TOKEN=<session-token-temporal>
